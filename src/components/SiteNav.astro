---
import { ChevronDown } from "@lucide/astro";

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const currentPath =
  pathname === "" || pathname === "/" || pathname === "/index.html"
    ? "/"
    : pathname;

const consultationPaths = new Set([
  "/psychotherapies-enfants-adolescents.html",
  "/psychotherapies-adultes.html",
  "/soutien-parental.html",
]);
const isConsultationsSection = consultationPaths.has(currentPath);

function linkCurrent(href: string) {
  return currentPath === href;
}
---

<nav class="nav" id="nav_state" aria-label="Navigation principale">
  <div class="nav__bar site-container">
    <ul class="nav__ul">
      <li class="nav__ul__li has-dropdown" data-nav-dropdown>
        <button
          type="button"
          class:list={[
            "nav__dropdown-trigger",
            { "nav__link--current": isConsultationsSection },
          ]}
          {...isConsultationsSection
            ? ({ "aria-current": "true" } as const)
            : {}}
          aria-expanded="false"
          aria-haspopup="true"
          aria-controls="site-nav-dropdown-consultations"
          id="site-nav-dropdown-consultations-btn"
        >
          <span class="nav__dropdown-label">Consultations</span>
          <ChevronDown
            class="icon lucide nav__dropdown-chevron"
            aria-hidden="true"
            size="1.1em"
            stroke-width="2.25"
          />
        </button>
        <ul
          class="dropdown"
          id="site-nav-dropdown-consultations"
          inert
          aria-label="Consultations"
        >
          <li>
            <a
              href="/psychotherapies-enfants-adolescents.html"
              class:list={[
                {
                  "nav__link--current": linkCurrent(
                    "/psychotherapies-enfants-adolescents.html",
                  ),
                },
              ]}
              {...linkCurrent("/psychotherapies-enfants-adolescents.html")
                ? ({ "aria-current": "page" } as const)
                : {}}
              aria-label="Consultations enfants et adolescents"
              >Consultations enfants et adolescents</a
            >
          </li>
          <li>
            <a
              href="/psychotherapies-adultes.html"
              class:list={[
                {
                  "nav__link--current": linkCurrent(
                    "/psychotherapies-adultes.html",
                  ),
                },
              ]}
              {...linkCurrent("/psychotherapies-adultes.html")
                ? ({ "aria-current": "page" } as const)
                : {}}
              aria-label="Consultations adultes">Consultations adultes</a
            >
          </li>
          <li>
            <a
              href="/soutien-parental.html"
              class:list={[
                {
                  "nav__link--current": linkCurrent("/soutien-parental.html"),
                },
              ]}
              {...linkCurrent("/soutien-parental.html")
                ? ({ "aria-current": "page" } as const)
                : {}}
              aria-label="Soutien parental et familial"
              >Soutien parental et familial</a
            >
          </li>
        </ul>
      </li>
      <li class="nav__ul__li">
        <a
          href="/bilan-psychologique.html"
          class:list={[
            { "nav__link--current": linkCurrent("/bilan-psychologique.html") },
          ]}
          {...linkCurrent("/bilan-psychologique.html")
            ? ({ "aria-current": "page" } as const)
            : {}}>Bilans psychologiques</a
        >
      </li>
      <li class="nav__ul__li">
        <a
          href="/cabinet-psychologue-castelneau.html"
          class:list={[
            {
              "nav__link--current": linkCurrent(
                "/cabinet-psychologue-castelneau.html",
              ),
            },
          ]}
          {...linkCurrent("/cabinet-psychologue-castelneau.html")
            ? ({ "aria-current": "page" } as const)
            : {}}>Le cabinet</a
        >
      </li>
      <li class="nav__ul__li">
        <a
          href="/emma-rouche-psychologue.html"
          class:list={[
            {
              "nav__link--current": linkCurrent(
                "/emma-rouche-psychologue.html",
              ),
            },
          ]}
          {...linkCurrent("/emma-rouche-psychologue.html")
            ? ({ "aria-current": "page" } as const)
            : {}}>Qui suis-je&nbsp;?</a
        >
      </li>
      <li class="nav__ul__li">
        <a
          href="/tarifs-psychologue.html"
          class:list={[
            { "nav__link--current": linkCurrent("/tarifs-psychologue.html") },
          ]}
          {...linkCurrent("/tarifs-psychologue.html")
            ? ({ "aria-current": "page" } as const)
            : {}}>Tarifs</a
        >
      </li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: var(--g-header-height);
    left: 0;
    right: 0;
    bottom: 0;
    width: auto;
    height: auto;
    overflow: hidden;
    z-index: 90;
    transform: translateX(-100%);
    transition: transform 0.28s cubic-bezier(0.32, 0.72, 0, 1);
    pointer-events: none;
  }
  @media (max-width: 47.99em) {
    :global(body.nav-menu-open) {
      overflow: hidden;
    }
  }
  @media (min-width: 48em) {
    .nav {
      position: relative;
      top: auto;
      right: auto;
      bottom: auto;
      left: 0;
      width: 100%;
      height: 75px;
      overflow: visible;
      background: none;
      box-shadow: 0 0 15px 0 #7c6e7f;
      z-index: 100;
      transform: none;
      transition: none;
      pointer-events: auto;
    }
  }
  .nav__bar {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    min-height: 100%;
  }
  @media (max-width: 47.99em) {
    .nav__bar {
      background: #afcb88;
    }
  }
  @media (min-width: 48em) {
    .nav__bar {
      flex-direction: row;
      align-items: stretch;
      justify-content: flex-start;
      gap: clamp(0.75rem, 2vw, 1.75rem);
      height: 100%;
      min-height: 0;
    }
  }
  .nav__ul {
    margin: 0;
    padding: 0;
    list-style: none;
    background: #afcb88;
  }
  @media (max-width: 47.99em) {
    .nav__ul {
      background: transparent;
    }
  }
  @media (min-width: 48em) {
    .nav__ul {
      display: flex;
      flex: 1 1 auto;
      flex-wrap: wrap;
      align-items: stretch;
      justify-content: flex-start;
      column-gap: 1.5em;
      row-gap: 0;
      overflow: visible;
      background: none;
      list-style: none;
    }
  }
  @media (min-width: 64em) {
    .nav__ul {
      column-gap: 2em;
    }
  }
  .nav__ul__li {
    border-bottom: 1px solid #fff;
  }
  @media (min-width: 48em) {
    .nav__ul__li {
      display: flex;
      align-items: center;
      align-self: stretch;
      overflow: visible;
      border: none;
      flex: 0 0 auto;
      background: none;
    }
  }
  .nav__ul__li a,
  .nav__ul__li .nav__dropdown-trigger {
    display: block;
    width: 100%;
    height: 100%;
    padding: 0 1em;
    transition: background 0.2s ease-out;
    background: none;
    color: #7c6e7f;
    font-family: var(--font-satisfy);
    font-size: 1.5rem;
    line-height: 80px;
    text-decoration: none;
    text-shadow: none;
  }
  @media (min-width: 48em) {
    .nav__ul__li > a {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      height: 100%;
      min-height: 75px;
      line-height: normal;
    }
    .nav__ul__li > .nav__dropdown-trigger {
      display: flex;
      align-items: center;
      height: 100%;
      min-height: 75px;
      line-height: normal;
    }
  }
  @media (max-width: 47.99em) {
    .nav__ul__li a,
    .nav__ul__li .nav__dropdown-trigger {
      color: #322b35;
    }
  }
  .nav__ul__li .nav__dropdown-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.45em;
    margin: 0;
    border: none;
    cursor: pointer;
    text-align: inherit;
    -webkit-appearance: none;
    appearance: none;
  }
  .nav__dropdown-label {
    flex: 1 1 auto;
    min-width: 0;
    text-align: inherit;
  }
  .nav__dropdown-chevron {
    flex-shrink: 0;
    width: 1.1em;
    height: 1.1em;
    transition: transform 0.2s ease-out;
  }
  .has-dropdown.is-open .nav__dropdown-chevron {
    transform: rotate(180deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .nav__dropdown-chevron {
      transition: none;
    }
  }
  @media (min-width: 48em) {
    .nav__ul__li .nav__dropdown-trigger {
      justify-content: center;
    }
    .nav__dropdown-label {
      flex: 0 1 auto;
    }
  }
  @media (min-width: 48em) {
    .nav__ul__li a,
    .nav__ul__li .nav__dropdown-trigger {
      font-size: 1.3rem;
    }
  }
  @media (min-width: 64em) {
    .nav__ul__li a,
    .nav__ul__li .nav__dropdown-trigger {
      font-size: 1.5rem;
    }
  }
  @media (min-width: 48em) {
    .nav__ul__li a,
    .nav__ul__li .nav__dropdown-trigger {
      width: auto;
      padding-left: 0;
      padding-right: 0;
    }
  }
  .nav__ul__li a.nav__link--current,
  .nav__ul__li .nav__dropdown-trigger.nav__link--current {
    color: #3f4f32;
  }
  @media (max-width: 47.99em) {
    .nav__ul__li a.nav__link--current,
    .nav__ul__li .nav__dropdown-trigger.nav__link--current {
      color: #3a5230;
    }
  }
  .nav__ul__li > a:hover,
  .nav__ul__li .nav__dropdown-trigger:hover {
    color: #556644;
  }
  .nav__ul__li .nav__dropdown-trigger:focus-visible {
    outline: 2px solid #7c6e7f;
    outline-offset: -4px;
  }
  .nav--open {
    transform: translateX(0);
    pointer-events: auto;
    overflow-x: hidden;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  @media (min-width: 48em) {
    .nav--open {
      max-height: none;
      overflow: visible;
      height: 100%;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .nav {
      transition: none;
    }
  }
  .has-dropdown {
    position: relative;
    height: 100%;
    color: #7c6e7f;
    font-family: var(--font-satisfy);
    font-size: 1.5em;
    line-height: 2.8;
    text-shadow: none;
    cursor: pointer;
  }
  @media (min-width: 48em) {
    .nav__ul__li.has-dropdown {
      font-size: inherit;
      line-height: normal;
    }
    .nav__ul__li.has-dropdown.is-open {
      z-index: 200;
    }
  }
  @media (max-width: 47.99em) {
    .has-dropdown {
      color: #322b35;
    }
  }
  @media (max-width: 47.99em) {
    .has-dropdown {
      height: auto;
      cursor: default;
    }
    .has-dropdown .nav__dropdown-trigger {
      display: none;
    }
    .has-dropdown .dropdown {
      position: static;
      left: auto;
      bottom: auto;
      width: 100%;
      max-height: none;
      height: auto;
      margin: 0;
      padding: 0;
      overflow: visible;
      list-style: none;
      background: transparent;
      visibility: visible;
      transition: none;
    }
    .has-dropdown.is-open .dropdown {
      max-height: none;
    }
    .dropdown li {
      line-height: 1.35;
      border-top: 1px solid rgb(255 255 255 / 0.35);
    }
    .dropdown li:first-child {
      border-top: none;
    }
    .has-dropdown .dropdown a {
      display: block;
      width: 100%;
      padding: 0.85em 1em 0.85em 1.45em;
      min-height: 0;
      line-height: 1.35;
      height: auto;
      color: #322b35;
      font-family: var(--font-satisfy);
      font-size: 1.5rem;
      text-decoration: none;
      text-shadow: none;
      box-sizing: border-box;
    }
    .has-dropdown .dropdown a:hover {
      background: #556644;
      color: #fff;
    }
    .has-dropdown .dropdown a.nav__link--current {
      color: #3a5230;
      background: rgb(175 203 136 / 0.28);
    }
    .has-dropdown .dropdown a.nav__link--current:hover {
      background: #556644;
      color: #fff;
    }
  }
  @media (min-width: 48em) {
    .has-dropdown.is-open .dropdown {
      top: 100%;
      right: auto;
      bottom: auto;
      left: 0;
      height: auto;
      min-height: 0;
      visibility: visible;
      z-index: 201;
    }
    .dropdown {
      position: absolute;
      bottom: 0;
      left: -1000px;
      z-index: 200;
      width: 17em;
      height: 0;
      transition: background 0.1s ease-in;
      background: #897d8c;
      visibility: hidden;
    }
    .dropdown li {
      line-height: 3;
    }
    .dropdown a {
      display: block;
      padding-left: 1.1em;
      color: #fff;
    }
    .dropdown a:hover {
      width: 100%;
      background: #556644;
      color: #fff;
    }
    .dropdown a.nav__link--current {
      background: rgb(175 203 136 / 0.28);
      color: #fff;
    }
    .dropdown a.nav__link--current:hover {
      background: #556644;
      color: #fff;
    }
  }
</style>
