---
import { MapPin, Menu, Phone } from "@lucide/astro";
import { LOCAL_BUSINESS, googleMapsSearchUrl } from "../data/local-seo";

const mapsUrl = googleMapsSearchUrl();

const addressOneLine = `${LOCAL_BUSINESS.streetAddress}, ${LOCAL_BUSINESS.postalCode} ${LOCAL_BUSINESS.addressLocality}`;
---

<header class="relative bg-header-bar py-3 md:py-4">
  <div class="site-container relative">
    <button
      type="button"
      class="nav-trigger tap-highlight-none absolute top-3 right-2 z-100 m-0 cursor-pointer border-0 bg-transparent p-0 font-inherit text-inherit leading-none md:hidden focus-visible:rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-sage focus-visible:ring-offset-4 focus-visible:ring-offset-header-bar"
      id="nav_trigger"
      aria-label="Ouvrir ou fermer le menu"
      aria-expanded="false"
      aria-controls="nav_state"
    >
      <Menu
        class="icon icon-burger block size-24 text-white transition-all duration-400 max-md:size-20"
        aria-hidden="true"
      />
    </button>

    <div
      class="flex flex-col gap-3 pr-14 md:flex-row md:flex-wrap md:items-center md:justify-between md:gap-x-8 md:gap-y-3 md:pr-8 lg:gap-x-10"
    >
      <div
        class="flex items-center gap-2 md:min-w-0 md:shrink-0 md:text-center"
      >
        <span
          class="text-xl leading-tight font-emma-script text-header-accent md:text-2xl"
          >{LOCAL_BUSINESS.name}</span
        >
        <span
          class="text-xs leading-snug font-medium tracking-wide text-header-muted"
          >{LOCAL_BUSINESS.title}</span
        >
      </div>

      <a
        class="flex min-w-0 max-w-full items-center gap-2 overflow-x-auto rounded-sm text-sm leading-snug text-header-muted no-underline transition-colors hover:text-header-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-sage focus-visible:ring-offset-2 focus-visible:ring-offset-header-bar md:max-w-none md:shrink md:justify-center"
        href={mapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Adresse du cabinet : ${LOCAL_BUSINESS.streetAddress}, ${LOCAL_BUSINESS.postalCode} ${LOCAL_BUSINESS.addressLocality}`}
      >
        <MapPin
          class="icon size-5 shrink-0 text-header-sage"
          aria-hidden="true"
        />
        <span class="whitespace-nowrap">{addressOneLine}</span>
      </a>

      <a
        class="inline-flex w-fit max-w-full items-center gap-2 rounded-full bg-header-tel-bg px-4 py-2 text-base font-semibold text-header-tel-text no-underline transition-colors hover:bg-brand-sage/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-sage focus-visible:ring-offset-2 focus-visible:ring-offset-header-bar md:px-5 md:py-2.5 md:text-lg"
        href={LOCAL_BUSINESS.telephoneHref}
        aria-label={`Appeler le ${LOCAL_BUSINESS.telephoneDisplay}`}
      >
        <Phone class="icon size-5 shrink-0 opacity-80" aria-hidden="true" />
        <span class="tabular-nums">{LOCAL_BUSINESS.telephoneDisplay}</span>
      </a>
    </div>
  </div>
</header>
