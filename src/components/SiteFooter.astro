              <a href="/psychotherapies-adultes.html">Consultations adultes</a>
            </li>
            <li class="footer-nav__ul__li">
              <a href="/soutien-parental.html">Soutien parental et familial</a>
            </li>
            <li class="footer-nav__ul__li">
              <a href="/bilan-psychologique.html">Bilans psychologiques</a>
            </li>
            <li class="footer-nav__ul__li">
