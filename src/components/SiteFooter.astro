---
import { Phone } from "@lucide/astro";
import { LOCAL_BUSINESS, googleMapsSearchUrl } from "../data/local-seo";

interface Props {
  copyrightRange?: string;
}
const { copyrightRange = "2016-2026" } = Astro.props;
const mapsUrl = googleMapsSearchUrl();
const nearbyCities = LOCAL_BUSINESS.areaServedCities.filter(
  (city) => city !== LOCAL_BUSINESS.addressLocality,
).join(", ");
---

<footer class="g-footer">
  <div class="g-footer__container site-container">
    <div class="g-footer__row">
      <section class="footer-sitemap span-4">
        <h3>Plan du site</h3>
        <nav class="footer-nav">
          <ul class="footer-nav__ul">
            <li class="footer-nav__ul__li">
              <a href="/">Accueil</a>
            </li>
            <li class="footer-nav__ul__li">
              <a href="/psychotherapies-enfants-adolescents/"
                >Consultations enfants et adolescents</a
              >
            </li>
            <li class="footer-nav__ul__li">
              <a href="/psychotherapies-adultes/">Consultations adultes</a>
            </li>
            <li class="footer-nav__ul__li">
              <a href="/soutien-parental/">Soutien parental et familial</a>
            </li>
            <li class="footer-nav__ul__li">
              <a href="/bilan-psychologique/">Bilans psychologiques</a>
            </li>
            <li class="footer-nav__ul__li">
              <a href="/cabinet-psychologue-castelneau/">Le cabinet</a>
            </li>
            <li class="footer-nav__ul__li">
              <a href="/emma-rouche-psychologue/">Qui suis-je&nbsp;?</a>
            </li>
            <li class="footer-nav__ul__li">
              <a href="/tarifs-psychologue/">Tarifs</a>
            </li>
            <li class="footer-nav__ul__li">
              <a href="/mentions-legales/">Mentions légales</a>
            </li>
          </ul>
        </nav>
      </section>
      <section class="footer-schema span-4">
        <h3>Emma Rouché</h3>
        <h4>Psychologue clinicienne</h4>
        <div class="footer-adress">
          <p>
            <a href={mapsUrl} target="_blank" rel="noopener noreferrer">
              {LOCAL_BUSINESS.streetAddress}
            </a>
          </p>
          <p>{LOCAL_BUSINESS.postalCode} {LOCAL_BUSINESS.addressLocality}</p>
        </div>
        <p class="footer-phone">
          <Phone class="icon icon-phone" aria-hidden="true" />
          <a href={LOCAL_BUSINESS.telephoneHref}>{LOCAL_BUSINESS.telephoneDisplay}</a>
        </p>
        <p>
          <a href={LOCAL_BUSINESS.emailHref}>{LOCAL_BUSINESS.email}</a>
        </p>
      </section>
      <section class="footer-infos span-4--l">
        <h3>Psychologue près des villes de</h3>
        <p>{nearbyCities}</p>
      </section>
    </div>
    <div class="copyright">
      <p>Tous droits réservés, Emma Rouché, {copyrightRange}</p>
      <p>
        Site réalisé par Nicodev, <a
          rel="nofollow"
          href="https://nicodev.fr">sites internet pour psychologues</a
        >
      </p>
    </div>
  </div>
</footer>

<style is:global>
  .g-footer {
    position: relative;
    padding-top: 1em;
    background-color: #2a2528;
    background-image: url(/images/footer-bg.png);
    background-repeat: repeat;
    background-position: 0 0;
    background-size: 400px 400px;
    color: #c5bcc7;
  }

  .g-footer::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgb(30 26 32 / 0.52);
    pointer-events: none;
  }

  .g-footer__container {
    position: relative;
    z-index: 1;
  }
  .g-footer__row {
    display: grid;
    row-gap: 1.5em;
  }
  @media (min-width: 64em) {
    .g-footer__row {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      column-gap: 2.85714%;
      align-items: start;
    }
    .g-footer__row .span-4,
    .g-footer__row .span-4--l {
      width: auto;
      float: none;
      margin-right: 0;
    }
  }
  .footer-phone {
    letter-spacing: 1px;
  }
  .footer-phone .icon-phone {
    color: #afcb88;
  }
  .g-footer__container h4,
  .g-footer h3 {
    color: #c5bcc7;
  }
  .footer-nav__ul__li {
    margin-bottom: 0.5em;
  }
  .footer-nav__ul__li a {
    background: none;
    color: #c5bcc7;
    font-family: var(--font-satisfy);
    text-shadow: none;
  }
  .footer-schema a,
  .footer-phone a {
    background: none;
    color: inherit;
    text-shadow: none;
  }
  .copyright {
    display: grid;
    row-gap: 0.5em;
  }
  @media (min-width: 64em) {
    .copyright {
      grid-template-columns: 1fr auto;
      align-items: baseline;
      column-gap: 1.5em;
    }
    .copyright p:first-of-type {
      justify-self: start;
    }
    .copyright p:last-of-type {
      justify-self: end;
      text-align: right;
    }
  }
  .copyright p:last-of-type a {
    background: none;
    text-shadow: none;
    color: #afcb88;
  }
</style>
