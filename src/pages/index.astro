---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeServiceCard from "../components/HomeServiceCard.astro";
import { getFaqJsonLd, LOCAL_BUSINESS } from "../data/local-seo";

const siteOrigin = (Astro.site ?? Astro.url).origin;
const extraJsonLd = getFaqJsonLd(siteOrigin, [
  {
    question: "Où se situe le cabinet de psychologie ?",
    answer:
      "Le cabinet d'Emma Rouché se situe au 25 avenue Aristide Briand, Bâtiment B, 34170 Castelnau-le-Lez, à proximité de Montpellier.",
  },
  {
    question: "Quels publics sont reçus au cabinet ?",
    answer:
      "Le cabinet reçoit des enfants, des adolescents, des adultes ainsi que des parents et des familles selon la demande.",
  },
  {
    question: "Comment prendre rendez-vous avec la psychologue ?",
    answer:
      "La prise de rendez-vous se fait par téléphone au 07 83 42 76 84 ou par email à erouche-psycho34@outlook.fr.",
  },
  {
    question: "Le cabinet est-il facilement accessible depuis Montpellier ?",
    answer:
      "Oui. Le cabinet de Castelnau-le-Lez est accessible depuis Montpellier, notamment par le tram ligne 2, et reçoit aussi des personnes venant des communes voisines comme Le Crès, Jacou, Clapiers, Vendargues ou Castries.",
  },
]);
---

<BaseLayout
  title="Psychologue à Castelnau-le-Lez | Emma Rouché"
  description="Psychologue clinicienne à Castelnau-le-Lez, près de Montpellier : consultations adultes, enfants et adolescents, bilans psychologiques et soutien parental."
  pageH1="Psychologue à Castelnau-le-Lez"
  extraJsonLd={extraJsonLd}
>
  <section>
    <div class="home-intro">
      <div class="home-intro__main">
        <div class="home-hero">
          <div class="home-hero__blobs" aria-hidden="true"></div>
          <div class="home-hero__inner">
            <p class="home-hero__kicker">Castelnau-le-Lez · Montpellier</p>
            <p class="home-hero__tagline">
              Un espace d'écoute pour enfants, adolescents, adultes et familles.
            </p>
          </div>
        </div>
        <header class="home-text">
          <h1>Psychologue à Castelnau-le-Lez</h1>

          <p>
            Psychologue clinicienne, je vous accueille au sein de mon cabinet, à
            Castelnau-le-Lez, à proximité immédiate de Montpellier, pour des
            consultations destinées aux enfants, aux adolescents, aux adultes et
            aux parents.
          </p>

          <p>
            Vous trouverez sur ce site les principales prises en charge proposées
            au cabinet ainsi que les informations pratiques pour préparer votre
            venue.
          </p>

        </header>
      </div>
      <aside class="home-intro__aside" aria-label="Informations professionnelles">
        <div class="home-block-tape has-tape">
          <h2>Emma Rouché, psychologue clinicienne</h2>
          <p>
            Psychologue clinicienne enregistrée à l’Agence Régionale de Santé
            (ARS) et au répertoire national des entreprises et des établissements
            (SIRENE) :
          </p>
          <div class="row">
            <div class="home-adelisiret">
              <p>N° ADELI : {LOCAL_BUSINESS.adeli}</p>
              <p>N° SIRET : {LOCAL_BUSINESS.siret}</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
    <div class="home-services-block">
      <header class="home-services-head">
        <p class="home-services-eyebrow">Accompagnement</p>
        <h2 class="home-services-title">Mes services</h2>
        <p class="home-services-lead">
          Des parcours adaptés aux enfants, aux adolescents, aux adultes et aux
          familles — chaque page détaille la prise en charge proposée.
        </p>
      </header>
      <div
        class="home-services-grid grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-10 lg:gap-12"
      >
        <HomeServiceCard
          title="Psychologue enfants et adolescents à Castelnau-le-Lez"
          paragraphs={[
            "L'approche psychothérapeutique avec les enfants et les adolescents s'appuie sur des médiations adaptées à leur âge, à leur vécu et à leur capacité d'expression.",
            "La page dédiée détaille les motifs de consultation fréquents à Castelnau-le-Lez et la manière dont un suivi peut se mettre en place.",
          ]}
          href="/psychotherapies-enfants-adolescents.html"
          linkLabel="Consultations enfants et adolescents"
        />
        <HomeServiceCard
          title="Psychothérapie pour adultes à Castelnau-le-Lez"
          paragraphs={[
            "Je propose au cabinet de Castelnau-le-Lez des psychothérapies pour adultes d'orientation analytique.",
            "Vous pouvez y découvrir mon approche, le déroulement de la première consultation et les modalités de suivi au cabinet.",
          ]}
          href="/psychotherapies-adultes.html"
          linkLabel="Consultations adultes"
        />
        <HomeServiceCard
          title="Bilan psychologique à Castelnau-le-Lez"
          paragraphs={[
            "Le bilan psychologique permet d'évaluer les compétences, le fonctionnement émotionnel et certains besoins spécifiques de l'enfant ou de l'adolescent.",
            "La page dédiée présente le déroulement du bilan, les tests utilisés et le cadre de restitution proposé au cabinet.",
          ]}
          href="/bilan-psychologique.html"
          linkLabel="Bilans psychologiques"
        />
        <HomeServiceCard
          title="Soutien parental et familial à Castelnau-le-Lez"
          paragraphs={[
            "Je propose aux parents et aux familles un espace d'accompagnement et de réflexion pour traverser des périodes de tension, de changement ou de doute.",
            "Vous y trouverez des repères sur les situations dans lesquelles un soutien familial et parental peut être utile.",
          ]}
          href="/soutien-parental.html"
          linkLabel="Soutien familial et parental"
        />
      </div>
    </div>
    <div class="row">
      <div class="has-img-border perch-paragraph">
        <h2>Cabinet de psychologie près de Montpellier et des communes voisines</h2>
        <p>
          Le cabinet reçoit des personnes venant de {LOCAL_BUSINESS.addressLocality},
          Montpellier, Le Crès, Vendargues, Clapiers, Montferrier-sur-Lez,
          Prades-le-Lez, Saint-Clément-de-Rivière, Jacou, Lunel et Castries.
        </p>
        <p>
          Cette implantation à Castelnau-le-Lez facilite l'accès au cabinet pour
          les habitants de l'est montpelliérain, avec des solutions de tram, de
          bus et de stationnement détaillées sur la page <a
            href="/cabinet-psychologue-castelneau.html">cabinet et accès</a>.
        </p>
        <p>
          Pour prendre rendez-vous, vous pouvez appeler le <a
            href={LOCAL_BUSINESS.telephoneHref}>{LOCAL_BUSINESS.telephoneDisplay}</a>
          ou écrire à <a href={LOCAL_BUSINESS.emailHref}>{LOCAL_BUSINESS.email}</a>.
        </p>
      </div>
    </div>
    <div class="row">
      <div class="has-img-border perch-paragraph">
        <h2>Questions fréquentes</h2>
        <h3>Où se situe le cabinet&nbsp;?</h3>
        <p>
          Le cabinet se situe au {LOCAL_BUSINESS.streetAddress}, {LOCAL_BUSINESS.postalCode}
          {" "}{LOCAL_BUSINESS.addressLocality}, à proximité de Montpellier.
        </p>
        <h3>Quels publics sont reçus&nbsp;?</h3>
        <p>
          Le cabinet reçoit des enfants, des adolescents, des adultes ainsi que
          des parents et des familles selon la demande.
        </p>
        <h3>Comment prendre rendez-vous&nbsp;?</h3>
        <p>
          Les rendez-vous se prennent par téléphone au <a
            href={LOCAL_BUSINESS.telephoneHref}>{LOCAL_BUSINESS.telephoneDisplay}</a>
          ou par email à <a href={LOCAL_BUSINESS.emailHref}>{LOCAL_BUSINESS.email}</a>.
        </p>
        <h3>Le cabinet est-il accessible depuis Montpellier&nbsp;?</h3>
        <p>
          Oui. Le cabinet de Castelnau-le-Lez est facilement accessible depuis
          Montpellier, notamment via le tram ligne 2.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
