---
import { Accessibility, Bus, MapPin, Phone } from "@lucide/astro";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import cabExtExterior from "../assets/images/cab-ext-1.jpg";
import cabExtParking from "../assets/images/cab-ext-2.jpg";
import {
  getFaqJsonLd,
  googleMapsIframeEmbedUrl,
  googleMapsSearchUrl,
  LOCAL_BUSINESS,
} from "../data/local-seo";

const mapEmbedSrc = googleMapsIframeEmbedUrl();
const mapsUrl = googleMapsSearchUrl();
const siteOrigin = (Astro.site ?? Astro.url).origin;
const extraJsonLd = getFaqJsonLd(siteOrigin, [
  {
    question: "Où se situe le cabinet de psychologie ?",
    answer:
      "Le cabinet se situe au 25 avenue Aristide Briand, Bâtiment B, 34170 Castelnau-le-Lez.",
  },
  {
    question: "Comment venir au cabinet depuis Montpellier ?",
    answer:
      "Le cabinet est accessible depuis Montpellier en tram ligne 2, arrêt Charles de Gaulle, ainsi qu'en bus.",
  },
  {
    question: "Peut-on se garer à proximité du cabinet ?",
    answer:
      "Oui. Un stationnement de proximité est possible, et le parking public du Vicarello se trouve à environ dix minutes à pied.",
  },
]);
---

<BaseLayout
  title="Cabinet de psychologue à Castelnau-le-Lez | Accès"
  description="Adresse, accès et prise de rendez-vous du cabinet de psychologie à Castelnau-le-Lez, près de Montpellier : tram, bus, stationnement et contact."
  extraJsonLd={extraJsonLd}
>
  <section class="g-page-section">
    <div class="span-8">
      <header class="has-paper-shadow">
        <h1>Cabinet de psychologie de Castelnau-le-Lez</h1>

        <p>
          Je vous accueille à mon cabinet de psychologie pour des <a
            href="/psychotherapies-enfants-adolescents.html"
            >psychothérapies d'enfants et d'adolescents</a
          >, des <a href="/psychotherapies-adultes.html"
            >psychothérapies d'adultes</a
          >, et <a href="/bilan-psychologique.html">bilans psychologiques</a>.
        </p>
      </header>
      <div class="has-img-border perch-paragraph">
        <div class="row has-svg-before">
          <MapPin class="icon icon-location icon-center" aria-hidden="true" />
          <h2>Adresse du cabinet</h2>
          <p>{LOCAL_BUSINESS.streetAddressLine1}</p>

          <p>{LOCAL_BUSINESS.streetAddressLine2}</p>

          <p>{LOCAL_BUSINESS.postalCode} {LOCAL_BUSINESS.addressLocality}</p>

          <p>
            Bâtiment derrière le laboratoire, premier étage, entrée par
            l’escalier en colimaçon.<br />
          </p>
          <p>
            <a href={mapsUrl} target="_blank" rel="noopener noreferrer">
              Ouvrir l'adresse dans Google Maps
            </a>
          </p>
        </div>
        <div class="row has-svg-before">
          <Bus class="icon icon-transport icon-center" aria-hidden="true" />
          <h2>Venir au cabinet</h2>
          <p><strong>Accessible en transport en commun </strong>:&nbsp;</p>

          <p>
            - Tram ligne 2 / arrêt «Charles De Gaulle» (à 3 minutes à pied).
          </p>

          <p>- Bus 35 et 36.</p>

          <p><br /></p>

          <p>
            <strong>Le stationnement</strong> à proximité immédiate est possible mais
            parfois compliqué.
          </p>

          <p><br /></p>

          <p>
            <strong>Parking public du Vicarello</strong> : au centre du village, situé
            à 10 minutes à pied du cabinet, vous trouverez un parking public facilement
            accessible (nombreuses places disponibles, 2h gratuites par demi-journée).<br
            />
          </p>

          <p><br /></p>
        </div>
        <div class="row has-svg-before">
          <Phone class="icon icon-phone icon-center" aria-hidden="true" />
          <h2>Prendre rendez-vous</h2>
          <p><a href={LOCAL_BUSINESS.telephoneHref}>{LOCAL_BUSINESS.telephoneDisplay}</a></p>
          <p><a href={LOCAL_BUSINESS.emailHref}>{LOCAL_BUSINESS.email}</a></p>
        </div>
        <div class="row has-svg-before">
          <Accessibility
            class="icon icon-disabled icon-center"
            aria-hidden="true"
          /><h2>Accès personnes en situation de handicap</h2>
          <p>
            Je me déplace à domicile pour les personnes en situation de
            handicap.
          </p>
        </div>
        <div class="row has-svg-before">
          <h2>Cabinet accessible depuis Montpellier et les communes voisines</h2>
          <p>
            Le cabinet reçoit également des patients venant de Montpellier, Le
            Crès, Jacou, Clapiers, Vendargues, Castries, Prades-le-Lez,
            Montferrier-sur-Lez, Saint-Clément-de-Rivière et Lunel.
          </p>
        </div>
      </div>
    </div>

    <div class="span-4--l">
      <div class="map-container">
        <iframe
          class="map-embed"
          title="Localisation du cabinet — Castelnau-le-Lez"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
          src={mapEmbedSrc}></iframe>
      </div>
      <Image
        class="img-cab-ext"
        src={cabExtExterior}
        alt="Cabinet de psychologie — vue extérieure"
        widths={[400, 800, 1200]}
        sizes="(max-width: 48em) 100vw, 33vw"
      />
      <Image
        class="img-cab-ext"
        src={cabExtParking}
        alt="Cabinet de psychologie — vue depuis le parking"
        widths={[400, 800, 1200]}
        sizes="(max-width: 48em) 100vw, 33vw"
      />

      <div class="has-tape">
        <ul>
          <li>Les consultations ont lieu sur rendez-vous.</li><li>
            Les séances ont une durée moyenne de 45 minutes.
          </li><li>
            La fréquence des séances dépend du besoin individuel. Généralement,
            les psychothérapies impliquent une consultation hebdomadaire ou
            bi-mensuelle.
          </li><li>
            La durée du suivi est très variable selon les besoins et les
            problématiques rencontrées. Dans certains cas, quelques séances
            suffisent.
          </li>
        </ul>
      </div>
      <div class="has-tape">
        <h2>Questions fréquentes</h2>
        <p>
          Depuis Montpellier, le tram ligne 2 permet de rejoindre facilement le
          cabinet, avec un arrêt à quelques minutes à pied.
        </p>
        <p>
          Le parking du Vicarello constitue une solution pratique lorsqu'il est
          difficile de stationner juste devant le cabinet.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
